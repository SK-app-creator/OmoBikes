<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f0f7f0">

    <!-- Green Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1b5e20"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="50dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="OmoBikes Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What are you looking for today?"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="12dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Answer 2 quick questions to find the right product"
            android:textColor="#a5d6a7"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Two Big Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Find a Cycle Button -->
        <LinearLayout
            android:id="@+id/btn_cycle_finder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/icon_bg"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚲"
                    android:textSize="26sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find a Cycle"
                    android:textColor="#111111"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Browse by type, budget &amp; brand"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="#2e7d32"
                android:textSize="22sp" />

        </LinearLayout>

        <!-- Spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- Find Cycle Parts Button -->
        <LinearLayout
            android:id="@+id/btn_parts_finder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/icon_bg"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔧"
                    android:textSize="26sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find Cycle Parts"
                    android:textColor="#111111"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search parts by type &amp; budget"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="#2e7d32"
                android:textSize="22sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="omobikes.com"
        android:textColor="#aaaaaa"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="16dp" />

</LinearLayout>
